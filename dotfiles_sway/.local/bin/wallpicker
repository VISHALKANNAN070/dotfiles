#!/usr/bin/env bash

# Use absolute paths
WALLDIR="$HOME/Pictures/wallpapers"
CACHE_DIR="$HOME/.cache/wall-thumbs"
# This path MUST match the one in your Sway config exactly
CURRENT_WALL="$HOME/.cache/current_wallpaper"

mkdir -p "$CACHE_DIR"

if ! command -v magick &> /dev/null; then
    echo "Error: ImageMagick is not installed."
    exit 1
fi

# Select image via Rofi
FILE=$(
for img in "$WALLDIR"/*; do
    [ -f "$img" ] || continue
    fname=$(basename "$img")
    thumb="$CACHE_DIR/$fname"
    if [ ! -f "$thumb" ]; then
        magick "$img" -thumbnail 300x300 "$thumb"
    fi
    printf "%s\0icon\x1f%s\n" "$fname" "$thumb"
done | rofi -dmenu -i -show-icons -p "Wallpaper" \
    -theme-str 'window { width: 60%; height: 50%; }' \
    -theme-str 'listview { lines: 2; columns: 5; }' \
    -theme-str 'element { orientation: vertical; }' \
    -theme-str 'element-icon { size: 180px; }'
)

[ -z "$FILE" ] && exit 0

WALLPAPER="$WALLDIR/$FILE"

# 1. Update the link (Force overwrite)
ln -sf "$WALLPAPER" "$CURRENT_WALL"

# 2. Apply colors
wal -i "$WALLPAPER" -n

# 3. Reload Sway 
# This will pick up the new colors AND the new wallpaper link
swaymsg reload

# 4. Force a manual update if the reload didn't catch the link change
swaymsg "output * bg \"$CURRENT_WALL\" fill"

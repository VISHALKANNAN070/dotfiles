HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000
setopt INTERACTIVE_COMMENTS

PROMPT='%F{109}%n-void%%%f '

alias c="clear"
alias q="exit"
alias v="nvim"
alias l="xbps-query -Rs"
alias g="sudo xbps-install -S"
alias f="yazi"
alias ff='fastfetch'
alias mem='ps_mem | tail -8'
alias lc='/home/vk/Localsend/localsend_app'
